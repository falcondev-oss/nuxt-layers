{
  "name": "@falcondev-oss/nuxt-layers-base",
  "type": "module",
  "version": "0.35.0",
  "description": "Nuxt layer with lots of useful helpers and @nuxt/ui components",
  "license": "MIT",
  "repository": "github:falcondev-oss/nuxt-layers",
  "bugs": {
    "url": "https://github.com/falcondev-oss/nuxt-layers/issues"
  },
  "main": "./nuxt.config.ts",
  "engines": {
    "node": "24",
    "pnpm": "11"
  },
  "scripts": {
    "dev": "nuxi dev .playground",
    "prepare": "nuxt prepare && nuxt prepare .playground",
    "type-check": "vue-tsc --build",
    "lint": "pnpm -w eslint:cmd \"$PWD\" && pnpm -w prettier:cmd \"$PWD\" --check",
    "lint:fix": "pnpm -w eslint:cmd \"$PWD\" --fix && pnpm -w prettier:cmd \"$PWD\" --write"
  },
  "peerDependencies": {
    "@falcondev-oss/form-core": ">=0.23.5",
    "@falcondev-oss/form-vue": ">=0.23.5",
    "@internationalized/date": ">=3.12.1",
    "@nuxt/ui": ">=4.9.0",
    "reka-ui": ">=2.9.10",
    "tailwind-variants": ">=3.2.2"
  },
  "dependencies": {
    "@falcondev-oss/trpc-typed-form-data": "^0.4.3",
    "@falcondev-oss/trpc-vue-query": "^0.5.4",
    "@iconify-json/lucide": "^1.2.114",
    "@nuxt/icon": "^2.2.3",
    "@nuxtjs/color-mode": "^4.0.1",
    "@tanstack/vue-query": "^5.101.0",
    "@trpc/client": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "@vue/devtools-api": "^8.1.3",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "@vueuse/router": "^14.3.0",
    "arkregex": "^0.0.5",
    "consola": "^3.4.2",
    "defu": "^6.1.7",
    "maska": "^3.2.0",
    "remeda": "^2.39.0",
    "superjson": "^2.2.6",
    "tailwindcss": "^4.3.1",
    "trpc-nuxt": "^2.1.1",
    "type-fest": "^5.7.0",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "nuxt": "^4.4.8",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.3.5",
    "zod": "^4.4.3"
  }
}
